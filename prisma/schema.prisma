generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Region {
  regionCode  String        @id @map("region_code") @db.VarChar(10)
  regionName  String        @map("region_name") @db.VarChar(50)
  subRegion   String?       @map("sub_region") @db.VarChar(50)
  reportCache ReportCache[]
  schools     School[]

  @@map("region")
}

model School {
  schoolCode         String               @id @map("school_code") @db.VarChar(20)
  schoolName         String               @map("school_name") @db.VarChar(100)
  schoolType         String               @map("school_type") @db.VarChar(20)
  regionCode         String               @map("region_code") @db.VarChar(10)
  district           String               @db.VarChar(50)
  latitude           Float?
  longitude          Float?
  address            String?              @db.VarChar(300)
  foundationType     String?              @map("foundation_type") @db.VarChar(20) // 설립명 (국립/공립/사립)
  foundationDate     String?              @map("foundation_date") @db.VarChar(20) // 설립일자
  phoneNumber        String?              @map("phone_number") @db.VarChar(30) // 전화번호
  homepageUrl        String?              @map("homepage_url") @db.VarChar(300) // 홈페이지주소
  coeducationType    String?              @map("coeducation_type") @db.VarChar(20) // 남녀공학구분
  highSchoolType     String?              @map("high_school_type") @db.VarChar(30) // 고교유형
  dayNightType       String?              @map("day_night_type") @db.VarChar(10) // 주야구분
  dataUpdatedAt      DateTime             @map("data_updated_at")
  afterschoolProgram AfterSchoolProgram[]
  financeStats       FinanceStats[]
  reportCache        ReportCache[]
  riskScore          RiskScore[]
  region             Region               @relation(fields: [regionCode], references: [regionCode])
  teacherStats       TeacherStats[]

  @@index([regionCode], map: "idx_school_region")
  @@index([schoolType], map: "idx_school_type")
  @@index([schoolName], map: "idx_school_name")
  @@map("school")
}

model TeacherStats {
  id                 String   @id @default(uuid())
  schoolCode         String   @map("school_code") @db.VarChar(20)
  year               Int
  studentsPerTeacher Float?   @map("students_per_teacher")
  tempTeacherRatio   Float?   @map("temp_teacher_ratio")
  totalTeachers      Int?     @map("total_teachers")
  totalStudents      Int?     @map("total_students")
  femaleTeachers     Int?     @map("female_teachers") // 여교원수
  maleTeachers       Int?     @map("male_teachers") // 남교원수
  lecturerCount      Int?     @map("lecturer_count") // 강사수
  currentClasses     Int?     @map("current_classes") // 현재 학급수
  authorizedClasses  Int?     @map("authorized_classes") // 인가 학급수
  source             String   @default("schoolinfo") @db.VarChar(50)
  collectedAt        DateTime @default(now()) @map("collected_at")
  school             School   @relation(fields: [schoolCode], references: [schoolCode])

  @@unique([schoolCode, year], name: "idx_teacher_school_year")
  @@index([year], map: "idx_teacher_year")
  @@map("teacher_stats")
}

model FinanceStats {
  id               String   @id @default(uuid())
  schoolCode       String   @map("school_code") @db.VarChar(20)
  year             Int
  totalBudget      BigInt?  @map("total_budget")
  educationBudget  BigInt?  @map("education_budget")
  budgetPerStudent Float?   @map("budget_per_student")
  source           String   @default("schoolinfo") @db.VarChar(50)
  collectedAt      DateTime @default(now()) @map("collected_at")
  school           School   @relation(fields: [schoolCode], references: [schoolCode])

  @@unique([schoolCode, year], name: "idx_finance_school_year")
  @@map("finance_stats")
}

model AfterSchoolProgram {
  id                        String   @id @default(uuid())
  schoolCode                String   @map("school_code") @db.VarChar(20)
  year                      Int
  subject                   String   @db.VarChar(100)
  enrollment                Int?
  category                  String?  @db.VarChar(50)
  academicEnrollment        Int?     @map("academic_enrollment") // 교과 수강학생수
  extracurricularEnrollment Int?     @map("extracurricular_enrollment") // 특기적성 수강학생수
  totalEnrollmentSum        Int?     @map("total_enrollment_sum") // 수강 연인원
  source                    String   @default("schoolinfo") @db.VarChar(50)
  collectedAt               DateTime @default(now()) @map("collected_at")
  school                    School   @relation(fields: [schoolCode], references: [schoolCode])

  @@index([schoolCode, year], map: "idx_afterschool_school_year")
  @@map("afterschool_program")
}

model RiskScore {
  id                  String   @id @default(uuid())
  schoolCode          String   @map("school_code") @db.VarChar(20)
  year                Int
  score               Float
  contributingFactors Json?    @map("contributing_factors")
  calculatedAt        DateTime @default(now()) @map("calculated_at")
  school              School   @relation(fields: [schoolCode], references: [schoolCode])

  @@unique([schoolCode, year], name: "idx_risk_school_year")
  @@map("risk_score")
}

model ReportCache {
  id               String   @id @default(uuid())
  schoolCode       String?  @map("school_code") @db.VarChar(20)
  regionCode       String?  @map("region_code") @db.VarChar(10)
  reportType       String   @map("report_type") @db.VarChar(20)
  reportContent    String   @map("report_content")
  modelUsed        String   @map("model_used") @db.VarChar(50)
  inputDataSummary Json?    @map("input_data_summary")
  generatedAt      DateTime @default(now()) @map("generated_at")
  expiresAt        DateTime @map("expires_at")
  region           Region?  @relation(fields: [regionCode], references: [regionCode])
  school           School?  @relation(fields: [schoolCode], references: [schoolCode])

  @@index([schoolCode, reportType], map: "idx_report_school_type")
  @@index([regionCode, reportType], map: "idx_report_region_type")
  @@index([expiresAt], map: "idx_report_expires")
  @@map("report_cache")
}

model ApiCache {
  id           String   @id @default(uuid())
  apiSource    String   @map("api_source") @db.VarChar(50)
  requestKey   String   @map("request_key") @db.VarChar(500)
  responseData Json     @map("response_data")
  cachedAt     DateTime @default(now()) @map("cached_at")
  expiresAt    DateTime @map("expires_at")

  @@unique([apiSource, requestKey], name: "idx_api_cache_key")
  @@map("api_cache")
}
